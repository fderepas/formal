# Rocq GCD: check the proofs and extract the OCaml (unary and native-int variants).
COQC ?= coqc

# Generated OCaml deliverables (both .ml and .mli per extraction).
GEN = rocq_gcd.ml rocq_gcd.mli rocq_gcd_int.ml rocq_gcd_int.mli

.PHONY: all clean distclean

# 'coqc Gcd.v' checks the proofs AND runs its Extraction; likewise Gcd_int.v.
all: $(GEN)

rocq_gcd.ml rocq_gcd.mli &: Gcd.v
	$(COQC) Gcd.v

rocq_gcd_int.ml rocq_gcd_int.mli &: Gcd_int.v
	$(COQC) Gcd_int.v

# Junk only: Coq build products, editor backups, OCaml objects, demo binaries.
clean:
	rm -f *.vo *.vok *.vos *.glob .*.aux *~ *.cmi *.cmo *.cmx *.o gcd_demo

# Also drop the extracted OCaml deliverables (regenerated by 'make').
distclean: clean
	rm -f $(GEN)
