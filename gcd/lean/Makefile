# Lean GCD: verify the proofs and (re)generate the C the Lean compiler emits.
LEAN ?= lean

.PHONY: all check clean distclean

# 'all' regenerates the showcased "proven C" from the verified source.
all: Gcd.c

Gcd.c: Gcd.lean
	$(LEAN) -c Gcd.c Gcd.lean

# Kernel-check the proofs (also runs the #eval sanity checks).
check: Gcd.lean
	$(LEAN) Gcd.lean

# Junk only: editor backups, olean caches, stray build products.
clean:
	rm -f *~ *.olean *.o

# Also drop the generated C deliverable (regenerated by 'make').
distclean: clean
	rm -f Gcd.c
